# =============================================================================
# RAG Pipeline Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and should never be committed.

# Application environment (development, staging, production)
RAG_ENVIRONMENT=development

# Logging level override (DEBUG, INFO, WARNING, ERROR, CRITICAL)
RAG_LOG_LEVEL=DEBUG

# Optional: API key for external LLM integration (not required for demo)
# RAG_API_KEY=your-api-key-here

# Optional: Custom path for vector store persistence
# RAG_PERSIST_DIRECTORY=./chroma_data
